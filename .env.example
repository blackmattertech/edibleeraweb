# ImageKit CDN — https://imagekit.io/dashboard/developer/api-keys
# Copy this file to `.env` and fill in your values. Never commit `.env`.

# Required — CDN base URL (safe for browser; used in Vite build)
VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/3dgbduo8k

# Optional — public key (needed for client-side upload widgets only)
VITE_IMAGEKIT_PUBLIC_KEY=public_avR9ASjS9x092

# Optional — ImageKit ID (same as URL path segment)
VITE_IMAGEKIT_ID=3dgbduo8k

# Server-side only — NEVER prefix with VITE_ (exposed to the browser if you do)
# Use only in a backend/API route for signed uploads or admin tasks — not in this Vite app
IMAGEKIT_PRIVATE_KEY=
